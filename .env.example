# Senha que Marcia/Matheus usarão para acessar a área administrativa em /admin
ADMIN_PASSWORD=troque-esta-senha

# Segredo usado para assinar o token temporário de sessão do convidado
# (emitido só depois do "Sim, sou eu"). Pode ser qualquer string aleatória longa.
RSVP_TOKEN_SECRET=troque-este-segredo-tambem

# Essas variáveis são preenchidas automaticamente pela Vercel quando você
# instala a integração de armazenamento "Upstash Redis" (Marketplace) no seu
# projeto. Não precisa criá-las manualmente — veja o README para o passo a passo.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
